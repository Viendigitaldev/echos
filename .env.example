APP_ENV=local
APP_DEBUG=true
APP_NAME="Echos"
APP_URL=http://localhost:8888/echos-dev
# Base path the app is served under when there is no dedicated vhost pointing
# straight at /public (e.g. MAMP serving from htdocs/echos-dev, forwarded to
# public/ via the root .htaccess). Leave empty when a vhost/production domain
# points DocumentRoot directly at /public.
APP_BASE_PATH=/echos-dev

DB_HOST=127.0.0.1
DB_PORT=8889
DB_SOCKET=/Applications/MAMP/tmp/mysql/mysql.sock
DB_DATABASE=echos_dev
DB_USERNAME=root
DB_PASSWORD=root

SESSION_NAME=echos_admin_session

# Outgoing mail (SMTP via PHPMailer) is configured from the admin Settings
# screen (/admin/settings), not here — see the `mail_*` keys in the
# `settings` table.
