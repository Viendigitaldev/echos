{
    "name": "echos/website",
    "description": "Echos AI marketing website with custom admin panel and SEO tooling",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": "^8.2",
        "ext-mbstring": "*",
        "ext-pdo": "*",
        "phpmailer/phpmailer": "^7.1"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        },
        "files": [
            "src/Support/helpers.php"
        ]
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    }
}
